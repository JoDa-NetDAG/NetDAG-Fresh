# BSC Mainnet Configuration
BSCSCAN_API_KEY=your_bscscan_api_key_here
PRIVATE_KEY=your_private_key_here
LIQUIDITY_FUND_ADDRESS=0xYourLiquidityFundAddressHere

# BSC Testnet Configuration  
TESTNET_PRIVATE_KEY=your_testnet_private_key_here

# RPC URLs (Optional - using public endpoints by default)
# BSC_MAINNET_RPC=https://bsc-dataseed1.binance.org
# BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545

# Configuration Notes:
# - Get BSCSCAN_API_KEY from: https://bscscan.com/myapikey
# - NEVER commit your actual .env file to GitHub
# - LIQUIDITY_FUND_ADDRESS: Where liquidity tokens will be sent
# - Keep your private keys safe and never share them